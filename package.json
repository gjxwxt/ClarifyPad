{
  "name": "clarifypad",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "probe:win:context": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-context-probe.ts",
    "probe:win:insert": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-insert-probe.ts",
    "probe:win:session": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-probe-session.ts",
    "probe:win:hotkey": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-hotkey-probe.ts",
    "probe:win:hotkey:listen": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-hotkey-listen.ts",
    "probe:win:doctor": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-doctor.ts",
    "probe:win:notepad": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-notepad-insert-check.ts",
    "probe:win:panel": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-probe-panel.ts",
    "probe:win:panel:record": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-probe-panel-record.ts",
    "probe:win:panel:notepad": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-panel-notepad-check.ts",
    "probe:win:matrix:probe": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-matrix-probe.ts",
    "probe:win:record": "node ./node_modules/tsx/dist/cli.mjs scripts/record-windows-app-verification.ts",
    "probe:win:summary": "node ./node_modules/tsx/dist/cli.mjs scripts/summarize-windows-app-verification.ts",
    "probe:win:matrix": "node ./node_modules/tsx/dist/cli.mjs scripts/run-windows-app-matrix-session.ts",
    "probe:mac:context": "node ./node_modules/tsx/dist/cli.mjs scripts/run-macos-context-probe.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
